{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Platform-agnostic design tokens for Optly (iOS/Android). Consume via codegen or runtime JSON parsing.",
  "meta": {
    "name": "Optly",
    "version": "1.0.0"
  },
  "color": {
    "primary": { "hex": "#5856D6", "description": "Indigo brand primary" },
    "secondary": { "hex": "#AF52DE", "description": "Purple accent" },
    "accent": { "hex": "#5AC8FA", "description": "Teal highlight" },
    "alert": { "hex": "#FF9500", "description": "Orange warning" },
    "success": { "hex": "#34C759", "description": "Green positive" },
    "background": {
      "light": { "hex": "#F2F2F7" },
      "dark": { "hex": "#000000" }
    },
    "surface": {
      "light": { "hex": "#FFFFFF" },
      "dark": { "hex": "#1C1C1E" }
    },
    "text": {
      "primary": {
        "light": { "hex": "#000000" },
        "dark": { "hex": "#FFFFFF" }
      },
      "secondary": {
        "light": { "hex": "#3C3C43", "alpha": 0.6 },
        "dark": { "hex": "#EBEBF5", "alpha": 0.6 }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["SF Pro Display", "SF Pro Text", "Roboto", "system-ui", "sans-serif"],
      "rounded": ["SF Pro Rounded", "Nunito", "system-ui", "sans-serif"]
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "heading": {
      "large": { "fontSize": 34, "lineHeight": 41, "fontWeight": 700, "letterSpacing": 0.37 },
      "medium": { "fontSize": 28, "lineHeight": 34, "fontWeight": 700, "letterSpacing": 0.36 },
      "small": { "fontSize": 22, "lineHeight": 28, "fontWeight": 600, "letterSpacing": 0.35 }
    },
    "body": {
      "large": { "fontSize": 17, "lineHeight": 22, "fontWeight": 400, "letterSpacing": -0.41 },
      "medium": { "fontSize": 15, "lineHeight": 20, "fontWeight": 400, "letterSpacing": -0.24 },
      "small": { "fontSize": 13, "lineHeight": 18, "fontWeight": 400, "letterSpacing": -0.08 }
    },
    "caption": {
      "default": { "fontSize": 12, "lineHeight": 16, "fontWeight": 500, "letterSpacing": 0 }
    }
  },
  "spacing": {
    "baseUnitPx": 4,
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64],
    "named": {
      "xs": 4,
      "sm": 8,
      "md": 12,
      "lg": 16,
      "xl": 20,
      "2xl": 24,
      "3xl": 32,
      "4xl": 40,
      "5xl": 48,
      "6xl": 64
    }
  },
  "radius": {
    "small": 8,
    "medium": 12,
    "large": 16,
    "pill": 999
  },
  "shadow": {
    "subtle": {
      "offsetY": 2,
      "blur": 8,
      "spread": 0,
      "color": { "light": { "hex": "#000000", "alpha": 0.08 }, "dark": { "hex": "#000000", "alpha": 0.4 } }
    },
    "medium": {
      "offsetY": 4,
      "blur": 16,
      "spread": 0,
      "color": { "light": { "hex": "#000000", "alpha": 0.12 }, "dark": { "hex": "#000000", "alpha": 0.5 } }
    },
    "strong": {
      "offsetY": 8,
      "blur": 24,
      "spread": 0,
      "color": { "light": { "hex": "#000000", "alpha": 0.16 }, "dark": { "hex": "#000000", "alpha": 0.6 } }
    }
  },
  "motion": {
    "durationMs": {
      "fast": 150,
      "normal": 300,
      "slow": 500
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "emphasized": "cubic-bezier(0.2, 0, 0, 1)"
    }
  }
}
