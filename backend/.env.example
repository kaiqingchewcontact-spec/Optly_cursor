# Copy to .env locally (never commit real secrets). Edge functions read these from Supabase Dashboard → Edge Functions → Secrets.

# Supabase (project URL + keys from Dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude (Anthropic) — used by daily-briefing, ai-insights, and health-triggered insight refresh
ANTHROPIC_API_KEY=sk-ant-api-...
# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Plaid — subscription-scan edge function
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# Sign in with Apple (native / OAuth) — team id is required for Apple developer setup;
# Supabase Auth also needs the Services ID + key (configure in Dashboard or via config.toml env() refs).
APPLE_TEAM_ID=your-apple-team-id

# Supabase Auth external providers (referenced from supabase/config.toml [auth.external.*])
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=com.example.app.service
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=your-apple-jwt-or-secret
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
